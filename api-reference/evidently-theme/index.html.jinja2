{% if root_module_name %}
{# Redirect index: add @view-transition so cross-document transitions work when navigating to evidently.html #}
<!doctype html>
<html>
<head>
    <meta charset="utf-8">
    <style>@view-transition{navigation:auto;}</style>
    <meta http-equiv="refresh" content="0; url=./{{ root_module_name.replace(".","/") }}.html"/>
</head>
</html>
{% else %}
{% extends "default/index.html.jinja2" %}

{% block nav %}

    {% include "version_header.html.jinja2" %}

    <h2>Available Modules</h2>
    <ul>
        {% for submodule in all_modules if "._" not in submodule and not submodule.startswith("_") %}
            <li><a href="{{ submodule.replace(".","/") }}.html">{{ submodule }}</a></li>
        {% endfor %}
    </ul>
{% endblock %}
{% endif %}
